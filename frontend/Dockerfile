# ── Build stage ───────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

# Vite embeds these at build time via import.meta.env.VITE_*
ARG VITE_ROTATE_ENABLED=false
ARG VITE_ROTATE_INTERVAL=20
ARG VITE_CO2_OK=800
ARG VITE_CO2_WARN=1000
ARG VITE_CO2_BAD=1500
ARG VITE_CO2_MAX=2000
ARG VITE_CO2_HISTORY=30
ARG VITE_TEMP_COLD=18
ARG VITE_TEMP_WARM=24
ARG VITE_TEMP_SCALE_MIN=10
ARG VITE_TEMP_SCALE_MAX=40
ARG VITE_PLANTS_PER_PAGE=3

ENV VITE_ROTATE_ENABLED=$VITE_ROTATE_ENABLED
ENV VITE_ROTATE_INTERVAL=$VITE_ROTATE_INTERVAL
ENV VITE_CO2_OK=$VITE_CO2_OK
ENV VITE_CO2_WARN=$VITE_CO2_WARN
ENV VITE_CO2_BAD=$VITE_CO2_BAD
ENV VITE_CO2_MAX=$VITE_CO2_MAX
ENV VITE_CO2_HISTORY=$VITE_CO2_HISTORY
ENV VITE_TEMP_COLD=$VITE_TEMP_COLD
ENV VITE_TEMP_WARM=$VITE_TEMP_WARM
ENV VITE_TEMP_SCALE_MIN=$VITE_TEMP_SCALE_MIN
ENV VITE_TEMP_SCALE_MAX=$VITE_TEMP_SCALE_MAX
ENV VITE_PLANTS_PER_PAGE=$VITE_PLANTS_PER_PAGE

RUN npm run build

# ── Serve stage ───────────────────────────────────────────────────────────────
FROM nginx:stable-alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
