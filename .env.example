# Copy to .env and fill in your values.
# Docker Compose reads this file automatically.

# ── Pi connection (used by manage.sh) ──────────────────────────────────────
PI_HOST=192.168.2.215
PI_USER=artfaal
PI_PATH=/home/artfaal/pi-dashboard

# ── Dashboard ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# ── Авторотация страниц ───────────────────────────────────────────────────────
VITE_ROTATE_ENABLED=false
VITE_ROTATE_INTERVAL=20

# ── CO2 виджет ────────────────────────────────────────────────────────────────
VITE_CO2_OK=800
VITE_CO2_WARN=1000
VITE_CO2_BAD=1500
VITE_CO2_MAX=2000
VITE_CO2_HISTORY=30

# ── Температура (TempRoomWidget) ──────────────────────────────────────────────
VITE_TEMP_COLD=18
VITE_TEMP_WARM=24
VITE_TEMP_SCALE_MIN=10
VITE_TEMP_SCALE_MAX=40

# ── Растения (PlantsWidget) ───────────────────────────────────────────────────
VITE_PLANTS_PER_PAGE=3

# ── CO2 sensor (co2mond Prometheus metrics) ──────────────────────────────────
CO2_METRICS_URL=http://co2mond:9999/metrics
CO2_INTERVAL=30

# ── Weather (Open-Meteo, no API key required) ─────────────────────────────────
WEATHER_LAT=55.7558
WEATHER_LON=37.6176
WEATHER_TZ=Europe/Moscow
WEATHER_LOCATION=Москва
WEATHER_INTERVAL=600

# ── Internet connectivity check ───────────────────────────────────────────────
INTERNET_INTERVAL=30

# ── Plants (tuya-exporter → Pushgateway) ─────────────────────────────────────
PLANTS_PUSHGATEWAY_URL=https://pushgateway.artfaal.ru
PLANTS_INTERVAL=300
PLANTS_IMAGE_BASE_URL=https://img.artfaal.ru/plants
PLANTS_IMAGE_TIMEOUT=10
PLANTS_PROXY_HOST=
PLANTS_PROXY_PORT=1080
PLANTS_PROXY_USER=
PLANTS_PROXY_PASSWORD=
